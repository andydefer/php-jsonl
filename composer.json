{
    "name": "andydefer/php-jsonl",
    "description": "High-performance JSONL (JSON Lines) file management library with temporal and key-based storage strategies, automatic batching, and cache expiration",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AndyDefer\\PhpJsonl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\PhpJsonl\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "andydefer/php-services": "^1.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "*",
        "vimeo/psalm": "^6.14",
        "friendsofphp/php-cs-fixer": "^3.95",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29"
    },
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite=unit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}